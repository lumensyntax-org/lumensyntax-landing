---
import '../styles/tokens.css';
import { site } from '../content/site.ts';
import { type Lang } from '../content/i18n.ts';
interface Props { title: string; description: string; lang: Lang }
const { title, description, lang } = Astro.props;
const p1 = site.paper1;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={new URL('/', Astro.site).href} />
    <link rel="alternate" hreflang="es" href={new URL('/es/', Astro.site).href} />
    <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site).href} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="citation_title" content={p1.title} />
    <meta name="citation_author" content={p1.authors} />
    <meta name="citation_doi" content={p1.versionDOI} />
    <meta name="citation_publication_date" content={p1.date} />
  </head>
  <body>
    <slot />
  </body>
</html>
