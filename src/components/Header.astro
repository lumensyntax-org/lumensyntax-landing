---
import { site } from '../content/site.ts';
const p = site.paper1;
// The "primary" link is the one we feature because it stays valid across paper versions.
const primaryDOI = p.primaryLink === 'concept' && p.conceptDOI ? p.conceptDOI : p.versionDOI;
---
<header>
  <p class="eyebrow">LUMENSYNTAX RESEARCH</p>
  <h1>{p.headline}</h1>
  {p.subtitle && <p class="subtitle">{p.subtitle}</p>}
  <p class="author">{p.authors} — Independent researcher, LumenSyntax</p>
  <p class="primary-doi">
    <a href={`https://doi.org/${primaryDOI}`}>Read the paper — doi.org/{primaryDOI}</a>
  </p>
  <dl class="meta">
    <dt>Version DOI</dt><dd><a href={`https://doi.org/${p.versionDOI}`}>{p.versionDOI}</a></dd>
    {p.conceptDOI && (<><dt>Concept DOI</dt><dd><a href={`https://doi.org/${p.conceptDOI}`}>{p.conceptDOI}</a></dd></>)}
    <dt>License</dt><dd>{p.license}</dd>
    <dt>Status</dt><dd>{p.status}</dd>
  </dl>
</header>
