---
import { site } from '../content/site.ts';
const e = site.ecclesia;
---
<section id="ecclesia">
  <h2>The Ecclesia</h2>
  <p>
    An open taxonomy of {e.entries} entries across {e.thematicDomains} thematic domains,
    plus a BUILDERS collection of {e.buildersProfiles} profiles. Each entry cites an established
    source and maps the finding to the five properties.
  </p>
  <p>{e.license} · <a href={e.repoUrl}>{e.repoUrl.replace('https://', '')}</a></p>
</section>
