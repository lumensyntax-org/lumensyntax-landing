---
import { site } from '../content/site.ts';
const b = site.benchmark;
const probe = site.probe;
---
<section id="availability">
  <h2>Availability</h2>
  <p class="gated-note">{site.gatedNote}</p>

  <h3>Publications</h3>
  <ul>
    <li><a href={`https://doi.org/${site.paper1.versionDOI}`}>{site.paper1.title}</a> — {site.paper1.license}</li>
    <li><a href={`https://doi.org/${site.paper2.versionDOI}`}>{site.paper2.title}</a> — {site.paper2.license}</li>
  </ul>

  <h3>Data &amp; Code</h3>
  <ul>
    <li>
      Benchmark: {b.cases.toLocaleString()} test cases across {b.categories} categories.
      Code: <a href={b.repoUrl}>{b.repoUrl.replace('https://', '')}</a>.
      Dataset: <a href={b.datasetUrl}>{b.dataLicense} on HuggingFace</a>{b.gated ? ' (gated)' : ''}.
    </li>
    <li>
      Probe: <a href={probe.url}>{probe.name}</a> — {probe.examples} examples across {probe.domains} domains
      ({probe.balance}), {probe.license}{probe.gated ? ', gated' : ', not gated'}. Companion to The Epistemic Equator.
    </li>
  </ul>
</section>
