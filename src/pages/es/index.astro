---
import Base from '../../layouts/Base.astro';
import LabHeader from '../../components/LabHeader.astro';
import Intro from '../../components/Intro.astro';
import Research from '../../components/Research.astro';
import Approach from '../../components/Approach.astro';
import ExecutionRules from '../../components/ExecutionRules.astro';
import Position from '../../components/Position.astro';
import Footer from '../../components/Footer.astro';
import { site } from '../../content/site.ts';
const lang = 'es';
const pos = site.lab.positions;
---
<Base lang={lang} title={`LumenSyntax — ${site.lab.name}`} description="LumenSyntax: un laboratorio de investigación sobre fidelidad epistemológica en modelos de lenguaje. Preprints abiertos, la taxonomía Ecclesia, un benchmark adversario, y la lectura del lab sobre seguridad epistémica.">
  <main>
    <LabHeader lang={lang} />
    <Intro lang={lang} />
    <Research lang={lang} />
    <Approach lang={lang} />
    <ExecutionRules lang={lang} />
    <Position num="05" heading={pos.structureRationale.heading} body={pos.structureRationale.body} lang={lang} />
    <Position num="06" heading={pos.futureOfEpistemicSafety.heading} body={pos.futureOfEpistemicSafety.body} lang={lang} />
    <Position num="07" heading={pos.whyItMatters.heading} body={pos.whyItMatters.body} lang={lang} />
    <Footer lang={lang} />
  </main>
</Base>
